#include <iostream>
#include <string>

using namespace std;

int contadorDeLeds(string &entrada){
    int contador=0;
    for(int i =0; i<entrada.size();i++){
        switch (entrada[i]){
        
            case '1':
                contador+=2;
                break;
        
            case '2':
            case '3':
            case '5':
                contador+=5;
                break;

            case '4':
                contador+=4;
                break;

            case '6':
            case '9':
            case '0':   
                contador+=6;
                break;

            case '7':
                contador+=3;
                break;

            case '8':
                contador+=7;
                break;
            
        default:
            break;
        }
    }
    return contador;
}

int main(){
    
    int n;// Casos de testes que irá ler.
    string v;

    if(cin>>n){
        for(int i=0; i<n; i++){
            cin>>v;
            cout<<contadorDeLeds(v)<<" leds"<<endl;
        }
    }

    return 0;
}
